runRenvRestore <- function() {
start <- Sys.time()
renv::restore(prompt = F)
end <- Sys.time()
duration <- end - start
list(
start = start,
end = end,
duration = duration,
seconds = as.numeric(duration, units = "secs")
)
}
output <- runRenvRestore()
output$duration
renv::record("yaml")
renv::restore()
renv::record("rmarkdown")
renv::restore()
